NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://homebase:homebase@localhost:5433/homebase
JWT_ACCESS_SECRET=replace_with_32+_char_random_string_aaaaaaaa
JWT_REFRESH_SECRET=replace_with_32+_char_random_string_bbbbbbbb
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=
CLIENT_URL=http://localhost:8081
# Use your Mac's LAN IP when testing on a physical device.
API_BASE_URL=http://192.168.0.115:4000

# Gmail SMTP (app password — not your regular Gmail password)
EMAIL_USERNAME=you@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=you@gmail.com

# Or Resend: RESEND_API_KEY=re_...

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
