    "/api/v1/listings": {
      "get": {
        "tags": ["Listings"],
        "summary": "Search listings",
        "description": "Faceted search over active listings. Money filters apply to type-specific price fields (kobo).",
        "parameters": [
          { "name": "type", "in": "query", "schema": { "type": "string", "enum": ["rent", "sale", "shortstay"] } },
          { "name": "q", "in": "query", "schema": { "type": "string" }, "description": "Title or city text search" },
          { "name": "minPrice", "in": "query", "schema": { "type": "integer" } },
          { "name": "maxPrice", "in": "query", "schema": { "type": "integer" } },
          { "name": "bedrooms", "in": "query", "schema": { "type": "integer" } },
          { "name": "bathrooms", "in": "query", "schema": { "type": "integer" } },
          { "name": "propertyType", "in": "query", "schema": { "type": "string" } },
          { "name": "amenities", "in": "query", "schema": { "type": "string" }, "description": "Comma-separated amenity slugs" },
          { "name": "sort", "in": "query", "schema": { "type": "string", "enum": ["recent", "priceAsc", "priceDesc"], "default": "recent" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "pageSize", "in": "query", "schema": { "type": "integer", "maximum": 50, "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "Paginated listings",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PaginatedListings" }
              }
            }
          },
          "400": {
            "description": "Invalid query",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          }
        }
      },
      "post": {
        "tags": ["Listings"],
        "summary": "Create listing",
        "description": "Create a rent, sale, or short-stay listing. Requires lister role. Body is discriminated by `listingType`.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateRentListingRequest" },
              "examples": {
                "rent": {
                  "summary": "Rental listing",
                  "value": {
                    "listingType": "rent",
                    "title": "3-bed flat in Lekki Phase 1",
                    "description": "Spacious flat with parking and 24/7 power.",
                    "propertyType": "apartment",
                    "bedrooms": 3,
                    "bathrooms": 2,
                    "amenities": ["parking", "generator"],
                    "address": "12 Admiralty Way",
                    "city": "Lagos",
                    "state": "Lagos",
                    "lat": 6.4474,
                    "lng": 3.47,
                    "rent": { "monthlyRent": 85000000, "securityDeposit": 85000000, "leaseTermMonths": 12 }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Listing created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Listing" } } }
          },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "403": { "description": "Seeker account — lister role required", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/listings/nearby": {
      "get": {
        "tags": ["Listings"],
        "summary": "Nearby listings",
        "description": "PostGIS proximity search. Returns active listings within `radius` meters of the given point, ordered by distance.",
        "parameters": [
          { "name": "lat", "in": "query", "required": true, "schema": { "type": "number" }, "example": 6.5244 },
          { "name": "lng", "in": "query", "required": true, "schema": { "type": "number" }, "example": 3.3792 },
          { "name": "radius", "in": "query", "schema": { "type": "integer", "default": 5000 }, "description": "Search radius in meters" },
          { "name": "type", "in": "query", "schema": { "type": "string", "enum": ["rent", "sale", "shortstay"] } }
        ],
        "responses": {
          "200": {
            "description": "Nearby listings with distanceMeters",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/NearbyListingsResponse" } } }
          },
          "400": { "description": "Invalid query", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/listings/{id}": {
      "get": {
        "tags": ["Listings"],
        "summary": "Get listing",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "Listing detail", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Listing" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "patch": {
        "tags": ["Listings"],
        "summary": "Update listing",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateListingRequest" } } }
        },
        "responses": {
          "200": { "description": "Updated listing", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Listing" } } } },
          "403": { "description": "Not the listing owner", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      },
      "delete": {
        "tags": ["Listings"],
        "summary": "Delete listing",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "204": { "description": "Deleted" },
          "403": { "description": "Not the listing owner", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "Not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/listings/{id}/status": {
      "patch": {
        "tags": ["Listings"],
        "summary": "Update listing status",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateListingStatusRequest" } } }
        },
        "responses": {
          "200": { "description": "Updated listing", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Listing" } } } },
          "403": { "description": "Not the listing owner", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/listings/{id}/photos/sign": {
      "post": {
        "tags": ["Listings"],
        "summary": "Sign Cloudinary upload",
        "description": "Returns signed upload params for direct client upload to Cloudinary.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": {
          "200": { "description": "Upload signature", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PhotoSignResponse" } } } },
          "403": { "description": "Not the listing owner", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/listings/{id}/photos": {
      "post": {
        "tags": ["Listings"],
        "summary": "Attach uploaded photo",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AddListingPhotoRequest" } } }
        },
        "responses": {
          "201": { "description": "Photo attached", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ListingPhoto" } } } },
          "403": { "description": "Not the listing owner", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/listings/{id}/photos/{photoId}": {
      "delete": {
        "tags": ["Listings"],
        "summary": "Remove photo",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "photoId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "204": { "description": "Photo removed" },
          "403": { "description": "Not the listing owner", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/v1/me/listings": {
      "get": {
        "tags": ["Listings"],
        "summary": "My listings",
        "description": "All listings owned by the authenticated lister.",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Owner listings", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MyListingsResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "403": { "description": "Lister role required", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
