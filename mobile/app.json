{
  "expo": {
    "name": "HomeBase",
    "slug": "homebase",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "homebase",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#15201D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.homebase.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "NSLocalNetworkUsageDescription": "HomeBase connects to the development API on your local network.",
        "NSLocationWhenInUseUsageDescription": "HomeBase uses your location to set your listing's map pin."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#EAF1EF"
      },
      "package": "com.homebase.app",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-status-bar",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#3B7A6F",
          "sounds": [],
          "enableBackgroundRemoteNotifications": false
        }
      ],
      "./plugins/withOptionalIosPush.js",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "HomeBase uses your location to set your listing's map pin."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#15201D",
          "image": "./assets/splash-icon.png",
          "imageWidth": 120,
          "resizeMode": "contain"
        }
      ]
    ]
  }
}
